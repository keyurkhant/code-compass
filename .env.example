# code-compass reads ~/.config/codecompass/config.toml for settings.
# Environment variables below OVERRIDE the config file.
# You do NOT need this file if you use `codecompass config set`.

# Override LLM provider:
# CODECOMPASS_LLM_PROVIDER=claude-code
# CODECOMPASS_LLM_MODEL=llama3.2
# CODECOMPASS_LLM_BASE_URL=http://localhost:11434

# Cloud API keys (only needed for litellm provider):
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
