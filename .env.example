# ── LLM provider ──────────────────────────────────────────────────────────────
# code-compass uses LiteLLM, so any provider works — just set the right key.
# Uncomment one block and fill in the key if needed.

# Anthropic Claude (install: pip install ".[anthropic]")
LLM_MODEL=claude-sonnet-4-5
ANTHROPIC_API_KEY=your-key-here

# OpenAI (install: pip install ".[openai]")
# LLM_MODEL=gpt-4o
# OPENAI_API_KEY=your-key-here

# Google Gemini (install: pip install ".[google]")
# LLM_MODEL=gemini/gemini-1.5-pro
# GEMINI_API_KEY=your-key-here

# Ollama — local, no API key needed (run `ollama pull llama3` first)
# LLM_MODEL=ollama/llama3

# Any OpenAI-compatible endpoint (Cursor, LM Studio, etc.)
# LLM_MODEL=openai/gpt-4o
# OPENAI_API_BASE=http://localhost:11434/v1
# OPENAI_API_KEY=optional

# ── Embeddings ─────────────────────────────────────────────────────────────────
# fastembed (ONNX-based, ~10× faster than sentence-transformers, no GPU needed).
# Models download once to ~/.cache/fastembed/
EMBEDDING_MODEL_NAME=jinaai/jina-embeddings-v2-base-code  # code-optimised, 768-dim
# EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5              # fastest option, 384-dim
EMBEDDING_BATCH_SIZE=32

# ── Vector store ───────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_PREFIX=codecompass

# ── BM25 index ────────────────────────────────────────────────────────────────
BM25_INDEX_PATH=./data/bm25_index.pkl

# ── Retrieval ─────────────────────────────────────────────────────────────────
TOP_K_RETRIEVE=10
TOKEN_BUDGET=6000

# ── API server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
